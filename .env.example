# Trading-R1 Backtest Configuration
# Copy this file to .env and fill in your API keys

# Required for LLM mode (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Finnhub API key (free tier) for news data
# Sign up at https://finnhub.io/ for a free key
FINNHUB_API_KEY=your-finnhub-api-key-here

# Required for GRPO mode (Hugging Face model downloads)
# Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=your-huggingface-token-here
